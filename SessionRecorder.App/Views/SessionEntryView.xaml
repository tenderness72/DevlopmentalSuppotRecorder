<UserControl x:Class="SessionRecorder.App.Views.SessionEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Entry form -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <Border Background="White" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="セッション記録" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                    <!-- Status message -->
                    <TextBlock Text="{Binding SaveMessage}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,8"
                               Visibility="{Binding SaveMessage, Converter={StaticResource StringToVis}}"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="日付"/>
                    <DatePicker SelectedDate="{Binding Date}" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="児童"/>
                    <ComboBox ItemsSource="{Binding Children}" SelectedItem="{Binding SelectedChild}"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding ChildCode}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Name}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="プログラム"/>
                    <ComboBox ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding ProgramCode}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ProgramName}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="試行数"/>
                            <TextBox Text="{Binding TrialCount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="正反応数"/>
                            <TextBox Text="{Binding CorrectCount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="正反応率"/>
                            <Border Background="{StaticResource BgBrush}" CornerRadius="4" Padding="8,7">
                                <TextBlock Text="{Binding CorrectRateDisplay}" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="クリア判定"/>
                            <ComboBox ItemsSource="{Binding MasteryLevels}" SelectedValue="{Binding MasteryLevel}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="プロンプトレベル"/>
                            <ComboBox ItemsSource="{Binding PromptLevels}" SelectedValue="{Binding PromptLevel}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="臨床メモ（観察事実）"/>
                    <TextBox Text="{Binding ClinicalNote, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="70" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="仮説/解釈"/>
                    <TextBox Text="{Binding Hypothesis, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="次回申し送り"/>
                    <TextBox Text="{Binding NextAction, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}">
                            <TextBlock>
                                <Run Text="{Binding IsEditMode, Converter={StaticResource BoolToSaveUpdate}, Mode=OneWay}"/>
                            </TextBlock>
                        </Button>
                        <Button Content="クリア" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding ClearFormCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Right: Recent records for selected child -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="直近のセッション記録" FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,12" Foreground="{StaticResource TextBrush}"/>
                <DataGrid ItemsSource="{Binding RecentRecords}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日付" Binding="{Binding Date, StringFormat=MM/dd}" Width="55"/>
                        <DataGridTextColumn Header="課題名" Binding="{Binding Program.ProgramName}" Width="140"/>
                        <DataGridTextColumn Header="試行" Binding="{Binding TrialCount}" Width="40"/>
                        <DataGridTextColumn Header="正答" Binding="{Binding CorrectCount}" Width="40"/>
                        <DataGridTextColumn Header="率" Binding="{Binding CorrectRate, Converter={StaticResource Percentage}}" Width="45"/>
                        <DataGridTextColumn Header="判定" Binding="{Binding MasteryLevel, Converter={StaticResource EnumToDisplay}}" Width="60"/>
                        <DataGridTextColumn Header="臨床メモ" Binding="{Binding ClinicalNote}" Width="180"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✏" FontSize="11" Cursor="Hand" Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
