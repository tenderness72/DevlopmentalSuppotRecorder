<UserControl x:Class="SessionRecorder.App.Views.ProgramTypeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="OnIsVisibleChanged">
    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Type list -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="型マスタ管理" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="プログラムの「型」を追加・編集・削除できます"
                           FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,8"/>
                <Button Content="＋ 新規追加" Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewTypeCommand}" HorizontalAlignment="Left"/>
            </StackPanel>

            <Border DockPanel.Dock="Top" Background="#FEF3C7" CornerRadius="6" Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ListBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,6" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                               FontSize="13" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="編集" ToolTip="この型を編集"
                                                FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                Foreground="White" Background="#2563EB"
                                                BorderThickness="0"
                                                Padding="8,3" Margin="0,0,5,0"
                                                Command="{Binding DataContext.EditTypeCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="削除" ToolTip="この型を削除"
                                                FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                Foreground="White" Background="#DC2626"
                                                BorderThickness="0"
                                                Padding="8,3"
                                                Command="{Binding DataContext.DeleteTypeCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- Right: Edit form -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <TextBlock Text="← 型を選択、または「新規追加」してください"
                           FontSize="14" Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="{Binding IsEditing, Converter={StaticResource InvBoolToVis}}"/>

                <StackPanel MaxWidth="420" HorizontalAlignment="Left"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16">
                        <Run Text="{Binding IsNewType, Converter={StaticResource BoolToNewEdit}, Mode=OneWay}"/>
                        <Run Text=" — 型"/>
                    </TextBlock>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="型コード（自動採番）"/>
                    <TextBox Text="{Binding EditTypeCode, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True" Background="#F9FAFB" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="型名"/>
                    <TextBox Text="{Binding EditTypeName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="備考（任意）"/>
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="保存" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveTypeCommand}"/>
                        <Button Content="キャンセル" Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
