<UserControl x:Class="SessionRecorder.App.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <TextBlock Grid.Row="0" Text="バックアップ・データ管理" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <!-- 上段：操作カード -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- バックアップカード -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="データのバックアップ" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,16">
                        起動時に1日1回自動でバックアップを作成します。<LineBreak/>
                        手動で今すぐバックアップすることもできます（30日分保持）。
                    </TextBlock>

                    <!-- バックアップフォルダパス -->
                    <TextBlock Text="保存先フォルダ" Style="{StaticResource FieldLabel}"/>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,6" Margin="0,0,0,12" Background="#F9FAFB">
                        <TextBlock Text="{Binding BackupFolderPath}"
                                   FontSize="11" Foreground="{StaticResource SubTextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="今すぐバックアップ" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateManualBackupCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBoolToVis}}"
                                Margin="0,0,8,0"/>
                        <Button Content="フォルダを開く" Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenBackupFolderCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- エクスポートカード -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="データのエクスポート" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,16">
                        データベースファイルを任意の場所にコピーします。<LineBreak/>
                        別のPCへの移行や外部保存に使用できます。
                    </TextBlock>
                    <Button Content="DB ファイルをエクスポート" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExportDbCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- バックアップ一覧 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="16,14,16,10">
                    <TextBlock Text="バックアップ履歴" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="{StaticResource SubTextBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <DataGrid ItemsSource="{Binding BackupFiles}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" RowHeaderWidth="0"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" FontSize="12">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#F9FAFB"/>
                            <Setter Property="Foreground"      Value="#374151"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,8"/>
                            <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="作成日時"
                                            Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd  HH:mm}"
                                            Width="160"/>
                        <DataGridTextColumn Header="ファイル名"
                                            Binding="{Binding FileName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="サイズ"
                                            Binding="{Binding FileSizeKb, StringFormat={}{0} KB}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
