<UserControl x:Class="SessionRecorder.App.Views.ProgramListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="プログラムマスタ" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            <Button Content="＋ 新規登録" Style="{StaticResource PrimaryButton}"
                    Command="{Binding NewProgramCommand}" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Edit form -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock Text="{Binding IsNewProgram, Converter={StaticResource BoolToNewEdit}}"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="プログラムコード"/>
                        <TextBox Text="{Binding EditProgramCode, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="プログラム名"/>
                        <TextBox Text="{Binding EditProgramName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="領域"/>
                        <ComboBox ItemsSource="{Binding Domains}" SelectedItem="{Binding EditDomain}"
                                  DisplayMemberPath="DomainName"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="型"/>
                        <ComboBox ItemsSource="{Binding ProgramTypes}" SelectedValue="{Binding EditProgramType}"
                                  SelectedValuePath="Value" DisplayMemberPath="DisplayName"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="達成基準"/>
                        <TextBox Text="{Binding EditMasteryCriteria, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="OnMasteryCriteriaLostFocus"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="備考"/>
                        <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="50"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="保存" Style="{StaticResource PrimaryButton}" Command="{Binding SaveProgramCommand}"/>
                    <Button Content="キャンセル" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Program list -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"
                      MouseDoubleClick="OnRowDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="コード" Binding="{Binding ProgramCode}" Width="80"/>
                    <DataGridTextColumn Header="プログラム名" Binding="{Binding ProgramName}" Width="240"/>
                    <DataGridTextColumn Header="領域" Binding="{Binding Domain.DomainName}" Width="100"/>
                    <DataGridTextColumn Header="型" Binding="{Binding ProgramType, Converter={StaticResource EnumToDisplay}}" Width="100"/>
                    <DataGridTextColumn Header="達成基準" Binding="{Binding MasteryCriteria}" Width="200"/>
                    <DataGridTextColumn Header="備考" Binding="{Binding Notes}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
