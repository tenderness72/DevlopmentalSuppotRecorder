<Window x:Class="SessionRecorder.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SessionRecorder.App.Views"
        xmlns:vm="clr-namespace:SessionRecorder.App.ViewModels"
        Title="支援記録データベース" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ChildListViewModel}">
            <views:ChildListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProgramListViewModel}">
            <views:ProgramListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionEntryViewModel}">
            <views:SessionEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ObservationEntryViewModel}">
            <views:ObservationEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SkillDomainListViewModel}">
            <views:SkillDomainListView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1F2937">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="支援記録" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="データベース" FontSize="12" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Margin="8,0">
                    <TextBlock Text="管理" FontSize="10" Foreground="#6B7280" Margin="12,0,0,6" FontWeight="SemiBold"/>
                    <Button Content="👤 児童一覧" Style="{StaticResource NavButton}" Command="{Binding NavigateToChildrenCommand}"/>
                    <Button Content="📋 プログラム管理" Style="{StaticResource NavButton}" Command="{Binding NavigateToProgramsCommand}"/>
                    <Button Content="🏷 領域管理" Style="{StaticResource NavButton}" Command="{Binding NavigateToSkillDomainsCommand}"/>

                    <Separator Background="#374151" Margin="12,12"/>

                    <TextBlock Text="記録" FontSize="10" Foreground="#6B7280" Margin="12,0,0,6" FontWeight="SemiBold"/>
                    <Button Content="📝 セッション入力" Style="{StaticResource NavButton}" Command="{Binding NavigateToSessionEntryCommand}"/>
                    <Button Content="👁 自然場面入力" Style="{StaticResource NavButton}" Command="{Binding NavigateToObservationEntryCommand}"/>

                    <Separator Background="#374151" Margin="12,12"/>

                    <TextBlock Text="分析" FontSize="10" Foreground="#6B7280" Margin="12,0,0,6" FontWeight="SemiBold"/>
                    <Button Content="🔍 横断検索" Style="{StaticResource NavButton}" Command="{Binding NavigateToSearchCommand}"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                           Foreground="#6B7280" FontSize="11" Margin="16,0,16,16" VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
