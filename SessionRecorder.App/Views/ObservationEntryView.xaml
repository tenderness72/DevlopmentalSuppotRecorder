<UserControl x:Class="SessionRecorder.App.Views.ObservationEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Entry form -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <Border Background="White" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="自然場面記録" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding SaveMessage}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,8"
                               Visibility="{Binding SaveMessage, Converter={StaticResource StringToVis}}"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="日付"/>
                    <DatePicker SelectedDate="{Binding Date}" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="児童"/>
                    <ComboBox ItemsSource="{Binding Children}" SelectedItem="{Binding SelectedChild}"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding ChildCode}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Name}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="記録タイプ"/>
                    <ComboBox ItemsSource="{Binding ObservationTypes}" SelectedValue="{Binding ObservationType}"
                              SelectedValuePath="Value" DisplayMemberPath="DisplayName" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="状況（先行事象）"/>
                    <TextBox Text="{Binding Situation, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="70" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="観察された行動"/>
                    <TextBox Text="{Binding ObservedBehavior, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="70" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="結果"/>
                    <ComboBox ItemsSource="{Binding ResponseResults}" SelectedValue="{Binding Result}"
                              SelectedValuePath="Value" DisplayMemberPath="DisplayName" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="臨床的解釈"/>
                    <TextBox Text="{Binding Interpretation, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="次回検証課題"/>
                    <TextBox Text="{Binding NextVerification, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}">
                            <TextBlock>
                                <Run Text="{Binding IsEditMode, Converter={StaticResource BoolToSaveUpdate}, Mode=OneWay}"/>
                            </TextBlock>
                        </Button>
                        <Button Content="クリア" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding ClearFormCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Right: Recent observations -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="直近の自然場面記録" FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,12" Foreground="{StaticResource TextBrush}"/>
                <DataGrid ItemsSource="{Binding RecentObservations}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="60" CanUserResize="False" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="編集" ToolTip="この記録を編集"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                            Foreground="White" Background="#2563EB"
                                            BorderThickness="0"
                                            Padding="8,3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Command="{Binding DataContext.EditObservationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="日付" Binding="{Binding Date, StringFormat=MM/dd}" Width="55"/>
                        <DataGridTextColumn Header="タイプ" Binding="{Binding ObservationType, Converter={StaticResource EnumToDisplay}}" Width="80"/>
                        <DataGridTextColumn Header="状況" Binding="{Binding Situation}" Width="160"/>
                        <DataGridTextColumn Header="行動" Binding="{Binding ObservedBehavior}" Width="160"/>
                        <DataGridTextColumn Header="結果" Binding="{Binding Result, Converter={StaticResource EnumToDisplay}}" Width="70"/>
                        <DataGridTextColumn Header="解釈" Binding="{Binding Interpretation}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
