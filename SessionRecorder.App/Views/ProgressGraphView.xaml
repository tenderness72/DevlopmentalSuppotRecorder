<UserControl x:Class="SessionRecorder.App.Views.ProgressGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right"
                    Content="画像として保存" Width="120"
                    Style="{StaticResource SecondaryButton}"
                    Click="OnSaveImageClick"
                    IsEnabled="{Binding HasData}"
                    VerticalAlignment="Center"/>
            <TextBlock Text="進捗グラフ" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左パネル：児童・プログラム選択 -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">

                <!-- 児童選択 -->
                <Border DockPanel.Dock="Top" Background="White" CornerRadius="8" Padding="14,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="児童" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Children}"
                                  SelectedItem="{Binding SelectedChild}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding ChildCode}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 前回プログラム -->
                        <TextBlock Text="{Binding LastProgramLabel}"
                                   FontSize="11" Foreground="#2563EB"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding LastProgramLabel, Converter={StaticResource StringToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- プログラム一覧 -->
                <Border DockPanel.Dock="Top" Background="White" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="プログラム" Style="{StaticResource FieldLabel}"
                                   Margin="14,12,14,6"/>
                        <ListBox ItemsSource="{Binding ProgramsForChild}"
                                 SelectedItem="{Binding SelectedProgramItem}"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Setter Property="Foreground" Value="#1D4ED8"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F9FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding LastDateDisplay, StringFormat='最終: {0}'}"
                                                   FontSize="10" Foreground="{StaticResource SubTextBrush}"
                                                   Margin="0,2,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- 右パネル：グラフ + サマリ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- サマリカード -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"
                        Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="セッション数" FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"/>
                            <TextBlock FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}">
                                <Run Text="{Binding SessionCount, Mode=OneWay}"/>
                                <Run Text=" 回" FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="平均正答率" FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"/>
                            <TextBlock Text="{Binding AvgRate}" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="最新正答率" FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"/>
                            <TextBlock Text="{Binding LatestRate}" FontSize="20" FontWeight="Bold"
                                       Foreground="#2563EB"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="初回→最新" FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"/>
                            <TextBlock Text="{Binding TrendText}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#059669"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- グラフ（データあり） -->
                <Border x:Name="ChartBorder"
                        Grid.Row="1" Background="White" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                    <lvc:CartesianChart Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        LegendPosition="Top"
                                        LegendTextPaint="{Binding LegendPaint}"
                                        TooltipTextPaint="{Binding TooltipPaint}"
                                        Margin="8"/>
                </Border>

                <!-- データなし・未選択メッセージ -->
                <Border Grid.Row="1" Background="White" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasData, Converter={StaticResource InvBoolToVis}}">
                    <TextBlock Text="児童とプログラムを選択するとグラフが表示されます"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
