<UserControl x:Class="SessionRecorder.App.Views.ObservationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SessionRecorder.App.Converters">

    <UserControl.Resources>
        <converters:EnumToDisplayConverter x:Key="EnumToDisplay"/>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right"
                    Content="CSV 出力" Width="90"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ExportCsvCommand}"
                    VerticalAlignment="Center"/>
            <TextBlock Text="自然場面記録一覧" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- フィルターバー -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 児童フィルター -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                    <TextBlock Text="児童：" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding Children}"
                              SelectedItem="{Binding FilterChild}"
                              Width="140" VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="ChildCode" TargetNullValue="すべて"/>
                                            <Binding Path="Name"      TargetNullValue=""/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- 日付範囲 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                    <TextBlock Text="期間：" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterFrom}" Width="130" VerticalAlignment="Center"/>
                    <TextBlock Text="〜" Margin="6,0" VerticalAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <DatePicker SelectedDate="{Binding FilterTo}" Width="130" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ボタン -->
                <Button Content="絞り込み" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyFilterCommand}"
                        Margin="0,0,8,4" VerticalAlignment="Center"/>
                <Button Content="クリア" Command="{Binding ClearFilterCommand}"
                        Padding="12,6" VerticalAlignment="Center" Margin="0,0,0,4"
                        Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                        Foreground="{StaticResource SubTextBrush}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- データグリッド -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding DisplayRecords}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F3F4F6"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      RowHeaderWidth="0"
                      FontSize="12"
                      Margin="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"   Value="#F9FAFB"/>
                        <Setter Property="Foreground"   Value="#374151"/>
                        <Setter Property="FontWeight"   Value="SemiBold"/>
                        <Setter Property="Padding"      Value="10,8"/>
                        <Setter Property="BorderBrush"  Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Padding" Value="0,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F9FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"          Value="10,6"/>
                        <Setter Property="BorderThickness"  Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- 編集・削除ボタン（左端） -->
                    <DataGridTemplateColumn Header="" Width="115" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                            VerticalAlignment="Center" Margin="2,0">
                                    <Button Content="編集" ToolTip="この記録を編集"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                            Foreground="White" Background="#2563EB"
                                            BorderThickness="0" Padding="8,3" Margin="0,0,5,0"
                                            Command="{Binding DataContext.RequestEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="削除" ToolTip="この記録を削除"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                            Foreground="White" Background="#DC2626"
                                            BorderThickness="0" Padding="8,3"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="日付"
                                        Binding="{Binding Date, StringFormat=yyyy/MM/dd}"
                                        Width="90"/>
                    <DataGridTextColumn Header="児童"
                                        Binding="{Binding Child.Name}"
                                        Width="80"/>
                    <DataGridTextColumn Header="タイプ"
                                        Binding="{Binding ObservationType, Converter={StaticResource EnumToDisplay}}"
                                        Width="80"/>
                    <DataGridTextColumn Header="状況"
                                        Binding="{Binding Situation}"
                                        Width="180"/>
                    <DataGridTextColumn Header="観察された行動"
                                        Binding="{Binding ObservedBehavior}"
                                        Width="200"/>
                    <DataGridTextColumn Header="結果"
                                        Binding="{Binding Result, Converter={StaticResource EnumToDisplay}}"
                                        Width="70"/>
                    <DataGridTextColumn Header="臨床的解釈"
                                        Binding="{Binding Interpretation}"
                                        Width="200"/>
                    <DataGridTextColumn Header="次回検証課題"
                                        Binding="{Binding NextVerification}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ステータスバー -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                   Foreground="{StaticResource SubTextBrush}" FontSize="12"
                   Margin="0,8,0,0"/>
    </Grid>
</UserControl>
